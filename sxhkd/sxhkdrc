suki#
# wm independent hotkeys
# terminal emulator
control + alt + t
	alacritty

# program launcher
super + d
	dmenu_run -h 34

super + e
	thunar

# make sxhkd reload its configuration files:
super + r
	pkill -USR1 -x sxhkd

#screenshot
super + shift + s
	maim -u -s | xclip -selection clipboard -t image/png

# bspwm hotkeys
# quit/restart bspwm
super + shift + {q,r}
	bspc {quit,wm -r}

# close and kill
super + q
	bspc node -c

#Switching desktop
super + 1
   	bspc desktop -f 1
super + 2
	bspc desktop -f 2
super + 3
    	bspc desktop -f 3
super + 4
    	bspc desktop -f 4
super + 5
    	bspc desktop -f 5
super + 6
    	bspc desktop -f 6
super + 7
    	bspc desktop -f 7
super + 8
    	bspc desktop -f 8
super + 9
    	bspc desktop -f 9
super + 0
    	bspc desktop -f 10

# focus or send to the given desktop
super + shift + 1
	bspc node -d 1
super + shift + 2
	bspc node -d 2
super + shift + 3
	bspc node -d 3
super + shift + 4
	bspc node -d 4
super + shift + 5
	bspc node -d 5
super + shift + 6
	bspc node -d 6
super + shift + 7
	bspc node -d 7
super + shift + 8
	bspc node -d 8
super + shift + 9
	bspc node -d 9
super + shift + 0
	bspc node -d 10

#alt-tabbing (kinda)
alt+tab
     	bspc node -f last

super + l
    betterlockscreen -l

# set the window state
super + {t,f,shift + f}
	bspc node -t {tiled,floating,fullscreen}

# move/resize
#change focus and move a window
super + shift + {h,j,k,l}
	bspc node -s {west,south,north,east}

# expand a window by moving one of its side outward
super + alt + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward
super + alt + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}
